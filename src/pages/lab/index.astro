---
import Base from '../../layouts/Base.astro';
---

<Base title="Lab" description="Prototypen, Visualisierungen und interaktive Experimente">
  <section class="page-header reveal">
    <div class="page-badge reveal reveal-delay-1">Werkstatt</div>
    <h1 class="reveal reveal-delay-2">Lab</h1>
    <p class="page-intro reveal reveal-delay-3">
      Hier entstehen Prototypen, interaktive Visualisierungen, Diagramme und Experimente.
      Alles, was ich ausprobiere und zeigen möchte.
    </p>
  </section>

  <section class="experiments">
    <div class="experiment reveal reveal-delay-3">
      <div class="exp-header">
        <div class="exp-number">01</div>
        <div class="exp-tag coming">Demnächst</div>
      </div>
      <h2>Interaktive Visualisierungen</h2>
      <p>D3.js-Charts, Netzwerk-Graphen und datengetriebene Darstellungen.</p>
      <div class="exp-tech">
        <span>D3.js</span>
        <span>React</span>
        <span>SVG</span>
      </div>
    </div>

    <div class="experiment reveal reveal-delay-4">
      <div class="exp-header">
        <div class="exp-number">02</div>
        <div class="exp-tag coming">Demnächst</div>
      </div>
      <h2>Prototypen</h2>
      <p>Kleine Apps und Tools, die ich für verschiedene Zwecke baue — von KI-Experimenten bis Alltagshelfer.</p>
      <div class="exp-tech">
        <span>Astro</span>
        <span>TypeScript</span>
        <span>APIs</span>
      </div>
    </div>

    <div class="experiment reveal reveal-delay-5">
      <div class="exp-header">
        <div class="exp-number">03</div>
        <div class="exp-tag coming">Demnächst</div>
      </div>
      <h2>Diagramme & Grafiken</h2>
      <p>Technische Architektur-Diagramme, Flowcharts und Infografiken zu Themen, die mich bewegen.</p>
      <div class="exp-tech">
        <span>Mermaid</span>
        <span>Canvas</span>
        <span>CSS</span>
      </div>
    </div>
  </section>

  <section class="cta reveal reveal-delay-6">
    <div class="cta-inner">
      <p>Du hast eine Idee für ein Experiment?</p>
      <a href="mailto:tobias.oberrauch@gmx.de">Schreib mir →</a>
    </div>
  </section>
</Base>

<style>
  .page-header {
    margin-bottom: 3rem;
  }

  .page-badge {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: var(--color-accent-light);
    padding: 0.3rem 0.9rem;
    border-radius: 99px;
    margin-bottom: 1.25rem;
  }

  .page-intro {
    color: var(--color-muted);
    font-size: 1.1rem;
    max-width: 560px;
    line-height: 1.7;
  }

  .experiments {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 4rem;
  }

  .experiment {
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2rem;
    transition: all var(--transition);
    position: relative;
    overflow: hidden;
  }

  .experiment::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-secondary));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .experiment:hover {
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .experiment:hover::after {
    transform: scaleX(1);
  }

  .exp-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .exp-number {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 300;
    color: var(--color-border-hover);
    line-height: 1;
    letter-spacing: -0.02em;
    font-variation-settings: 'opsz' 72;
  }

  .exp-tag {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.25rem 0.7rem;
    border-radius: 99px;
  }
  .exp-tag.coming {
    background: var(--color-bg-alt);
    color: var(--color-muted);
    border: 1px solid var(--color-border);
  }
  .exp-tag.live {
    background: #D5EDE2;
    color: #15603D;
  }

  .experiment h2 {
    font-size: 1.3rem;
    margin: 0 0 0.5rem;
    font-weight: 600;
  }

  .experiment p {
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .exp-tech {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .exp-tech span {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-muted);
    background: var(--color-bg-alt);
    padding: 0.2rem 0.65rem;
    border-radius: 6px;
    border: 1px solid var(--color-border);
  }

  .cta {
    margin-top: 1rem;
  }
  .cta-inner {
    background: var(--color-bg-alt);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius);
    padding: 2rem;
    text-align: center;
  }
  .cta-inner p {
    color: var(--color-muted);
    margin-bottom: 0.5rem;
    font-size: 1rem;
  }
  .cta-inner a {
    font-weight: 500;
    font-size: 1rem;
  }
</style>
