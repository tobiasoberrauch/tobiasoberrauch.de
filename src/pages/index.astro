---
import Base from '../layouts/Base.astro';
---

<Base title="Home">
  <section class="hero">
    <h1>Hallo, ich bin Tobias.</h1>
    <p class="lead">
      Software Engineer aus Holzmaden. Ich interessiere mich fuer KI, Hochbegabung
      und baue gerne Prototypen, die komplexe Themen greifbar machen.
    </p>
  </section>

  <section class="cards">
    <a href="/hochbegabung/" class="card">
      <h2>Hochbegabung</h2>
      <p>Recherchen, Artikel und Ressourcen rund um Hochbegabung bei Kindern und Erwachsenen.</p>
    </a>
    <a href="/lab/" class="card">
      <h2>Lab</h2>
      <p>Prototypen, interaktive Visualisierungen, Diagramme und Experimente.</p>
    </a>
    <a href="/about/" class="card">
      <h2>About</h2>
      <p>Ueber mich, meine Projekte und wie du mich erreichen kannst.</p>
    </a>
  </section>
</Base>

<style>
  .hero { margin-bottom: 3rem; }
  .hero h1 { margin-top: 0; font-size: 2.5rem; }
  .lead { font-size: 1.2rem; color: var(--color-muted); max-width: 560px; }
  .cards { display: grid; gap: 1.5rem; }
  .card {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    color: var(--color-text);
  }
  .card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 2px 12px rgba(37, 99, 235, 0.08);
    text-decoration: none;
  }
  .card h2 { margin-top: 0; font-size: 1.3rem; }
  .card p { color: var(--color-muted); margin-bottom: 0; }
</style>
