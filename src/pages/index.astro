---
import Base from '../layouts/Base.astro';
import HeroCanvas from '../components/HeroCanvas';
import WaveSection from '../components/WaveSection';
---

<Base title="Home">
  <section class="hero reveal">
    <div class="hero-canvas-wrap">
      <HeroCanvas client:load />
    </div>
    <div class="hero-content">
      <div class="hero-badge reveal reveal-delay-1">Software Engineer · KI · Hochbegabung</div>
      <h1 class="reveal reveal-delay-2">
        Hallo, ich bin<br/><span class="name-highlight">Tobias</span>.
      </h1>
      <p class="lead reveal reveal-delay-3">
        Ich baue Dinge, die komplexe Themen greifbar machen — von künstlicher Intelligenz
        bis zur Förderung hochbegabter Kinder.
      </p>
      <div class="hero-links reveal reveal-delay-4">
        <a href="/hochbegabung/" class="btn-primary">Hochbegabung entdecken</a>
        <a href="/ueber-mich/" class="btn-ghost">Mehr über mich</a>
      </div>
    </div>
  </section>

  <div class="wave-divider">
    <WaveSection client:visible />
  </div>

  <section class="section-intro scroll-reveal">
    <h2 class="section-label">Was mich bewegt</h2>
    <p class="section-desc">
      Drei Bereiche, die mich antreiben — und die ich hier mit euch teile.
    </p>
  </section>

  <section class="cards">
    <a href="/hochbegabung/" class="card scroll-reveal">
      <div class="card-visual card-visual-hb">
        <svg viewBox="0 0 200 120" fill="none">
          <circle cx="100" cy="60" r="40" stroke="#B45309" stroke-width="1" opacity="0.3"/>
          <circle cx="100" cy="60" r="25" stroke="#B45309" stroke-width="1.5" opacity="0.5"/>
          <circle cx="100" cy="60" r="10" fill="#B45309" opacity="0.7"/>
          <circle cx="60" cy="40" r="4" fill="#D97706" opacity="0.5"/>
          <circle cx="140" cy="80" r="4" fill="#D97706" opacity="0.5"/>
          <circle cx="130" cy="35" r="3" fill="#4D7C6A" opacity="0.5"/>
          <circle cx="70" cy="85" r="3" fill="#4D7C6A" opacity="0.5"/>
          <line x1="100" y1="60" x2="60" y2="40" stroke="#B45309" stroke-width="0.5" opacity="0.3"/>
          <line x1="100" y1="60" x2="140" y2="80" stroke="#B45309" stroke-width="0.5" opacity="0.3"/>
          <line x1="100" y1="60" x2="130" y2="35" stroke="#4D7C6A" stroke-width="0.5" opacity="0.3"/>
          <line x1="100" y1="60" x2="70" y2="85" stroke="#4D7C6A" stroke-width="0.5" opacity="0.3"/>
          <text x="100" y="63" text-anchor="middle" font-size="10" font-family="Outfit" fill="#B45309" font-weight="600">2%</text>
        </svg>
      </div>
      <div class="card-body">
        <h2>Hochbegabung</h2>
        <p>Recherchen, Artikel und Ressourcen für Familien hochbegabter Kinder in Baden-Württemberg.</p>
        <span class="card-link">Zum Bereich →</span>
      </div>
    </a>

    <a href="/lab/" class="card scroll-reveal sr-delay-1">
      <div class="card-visual card-visual-lab">
        <svg viewBox="0 0 200 120" fill="none">
          <rect x="30" y="20" width="140" height="80" rx="8" stroke="#D97706" stroke-width="0.8" opacity="0.2"/>
          <polyline points="40,80 65,55 85,68 110,35 135,50 160,25" stroke="#B45309" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" opacity="0.6"/>
          <polyline points="40,85 70,70 100,75 130,60 160,65" stroke="#4D7C6A" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/>
          <circle cx="110" cy="35" r="4" fill="#B45309" opacity="0.7"/>
          <circle cx="160" cy="25" r="3" fill="#B45309" opacity="0.5"/>
          <circle cx="65" cy="55" r="3" fill="#B45309" opacity="0.5"/>
        </svg>
      </div>
      <div class="card-body">
        <h2>Lab</h2>
        <p>Prototypen, interaktive Visualisierungen, Diagramme und technische Experimente.</p>
        <span class="card-link">Erkunden →</span>
      </div>
    </a>

    <a href="/ueber-mich/" class="card scroll-reveal sr-delay-2">
      <div class="card-visual card-visual-about">
        <svg viewBox="0 0 200 120" fill="none">
          <circle cx="100" cy="45" r="20" stroke="#B45309" stroke-width="1.5" opacity="0.4"/>
          <path d="M65 95 A40 30 0 0 1 135 95" stroke="#B45309" stroke-width="1.5" fill="none" opacity="0.3"/>
          <circle cx="60" cy="65" r="10" stroke="#4D7C6A" stroke-width="1" opacity="0.3"/>
          <circle cx="140" cy="65" r="10" stroke="#4D7C6A" stroke-width="1" opacity="0.3"/>
          <line x1="70" y1="65" x2="90" y2="55" stroke="#78716C" stroke-width="0.5" opacity="0.3"/>
          <line x1="130" y1="65" x2="110" y2="55" stroke="#78716C" stroke-width="0.5" opacity="0.3"/>
          <circle cx="100" cy="45" r="6" fill="#B45309" opacity="0.15"/>
        </svg>
      </div>
      <div class="card-body">
        <h2>Über mich</h2>
        <p>Wer ich bin, woran ich glaube und wie du mich erreichen kannst.</p>
        <span class="card-link">Kennenlernen →</span>
      </div>
    </a>
  </section>

  <!-- Quote -->
  <section class="quote-section scroll-reveal">
    <blockquote>
      „Hochbegabung ist kein Luxusproblem, sondern ein Förderbedarf."
    </blockquote>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    min-height: 420px;
    display: flex;
    align-items: center;
    margin: -4rem -1.5rem 0;
    padding: 4rem 1.5rem 3rem;
    overflow: hidden;
  }

  .hero-canvas-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 560px;
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: rgba(254, 243, 199, 0.85);
    backdrop-filter: blur(8px);
    padding: 0.35rem 1rem;
    border-radius: 99px;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(180, 83, 9, 0.1);
  }

  .hero h1 {
    font-size: clamp(3rem, 8vw, 4.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
    font-variation-settings: 'opsz' 144;
  }

  .name-highlight {
    background: linear-gradient(135deg, var(--color-accent), #D97706, #92400E);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .lead {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--color-muted);
    max-width: 480px;
    margin-bottom: 2rem;
  }

  .hero-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.6rem;
    background: var(--color-accent);
    color: white;
    font-weight: 500;
    font-size: 0.95rem;
    border-radius: 12px;
    transition: all var(--transition);
    text-decoration: none;
    box-shadow: 0 2px 16px var(--color-accent-glow);
  }
  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 6px 24px var(--color-accent-glow);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.6rem;
    color: var(--color-text-soft);
    font-weight: 500;
    font-size: 0.95rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    transition: all var(--transition);
    text-decoration: none;
    background: rgba(255,255,255,0.5);
    backdrop-filter: blur(8px);
  }
  .btn-ghost:hover {
    border-color: var(--color-border-hover);
    background: rgba(255,255,255,0.8);
    color: var(--color-text);
  }

  .wave-divider {
    margin: 0 -1.5rem;
    overflow: hidden;
    line-height: 0;
  }

  .section-intro {
    text-align: center;
    margin: 3rem 0 2.5rem;
  }
  .section-label {
    font-size: 1.6rem;
    margin-top: 0;
    margin-bottom: 0.5rem;
  }
  .section-desc {
    color: var(--color-muted);
    font-size: 1.05rem;
    max-width: 420px;
    margin: 0 auto;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .card {
    position: relative;
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: all var(--transition);
    color: var(--color-text);
    text-decoration: none;
  }
  .card:hover {
    border-color: var(--color-accent);
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    text-decoration: none;
    color: var(--color-text);
  }

  .card-visual {
    padding: 1.5rem 1.5rem 0.5rem;
    display: flex;
    justify-content: center;
    transition: all var(--transition);
  }
  .card-visual svg {
    width: 100%;
    max-width: 200px;
    height: auto;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .card:hover .card-visual svg {
    transform: scale(1.05);
  }

  .card-body {
    padding: 0.5rem 1.75rem 1.75rem;
  }

  .card h2 {
    font-size: 1.3rem;
    margin: 0 0 0.4rem;
    font-weight: 600;
  }

  .card p {
    color: var(--color-muted);
    font-size: 0.93rem;
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .card-link {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-accent);
  }

  .quote-section {
    max-width: 520px;
    margin: 0 auto 2rem;
  }
  .quote-section blockquote {
    text-align: center;
    border-left: none;
    border-radius: var(--radius);
    padding: 2rem;
    font-size: 1.15rem;
  }

  @media (max-width: 640px) {
    .hero { min-height: 360px; padding-top: 2rem; }
    .hero h1 { font-size: 2.6rem; }
    .cards { grid-template-columns: 1fr; }
  }
</style>
