---
import Base from '../../layouts/Base.astro';
import StatsRing from '../../components/StatsRing';

const mdxFiles = import.meta.glob('../../content/hochbegabung/*.mdx', { eager: true });
const articles = Object.entries(mdxFiles).map(([path, mod]: [string, any]) => ({
  title: mod.frontmatter?.title || path.split('/').pop()?.replace('.mdx', ''),
  date: mod.frontmatter?.date,
  description: mod.frontmatter?.description || '',
  slug: path.split('/').pop()?.replace('.mdx', ''),
}));
---

<Base title="Hochbegabung" description="Recherchen, Artikel und Ressourcen rund um Hochbegabung">
  <section class="page-header reveal">
    <div class="page-badge reveal reveal-delay-1">Wissen & Erfahrung</div>
    <h1 class="reveal reveal-delay-2">Hochbegabung</h1>
    <p class="page-intro reveal reveal-delay-3">
      Informationen, Recherchen und persönliche Erfahrungen zum Thema Hochbegabung
      bei Kindern und Erwachsenen. Als Elterngruppenleiter beim
      <a href="https://lvh-bw.de" target="_blank" rel="noopener">LVH Baden-Württemberg</a>
      sammle ich hier Wissen für Familien.
    </p>
  </section>

  <!-- Infographic stats -->
  <section class="stats-section scroll-reveal">
    <h2 class="stats-title">Hochbegabung in Zahlen</h2>
    <div class="stats-grid">
      <div class="stat-item">
        <StatsRing client:visible value={2} max={100} label="der Bevölkerung" suffix="%" color="#B45309" size={130} />
      </div>
      <div class="stat-item">
        <StatsRing client:visible value={130} max={200} label="IQ-Schwelle" suffix="+" color="#D97706" size={130} />
      </div>
      <div class="stat-item">
        <StatsRing client:visible value={320} max={500} label="Familien im LVH" color="#4D7C6A" size={130} />
      </div>
      <div class="stat-item">
        <StatsRing client:visible value={20} max={30} label="Elterngruppen BaWü" color="#92400E" size={130} />
      </div>
    </div>
  </section>

  <!-- Visual topic map -->
  <section class="topic-map scroll-reveal">
    <h2 class="section-heading">
      <span class="heading-line"></span>
      Themenbereiche
    </h2>

    <div class="topics-visual">
      <div class="topic-card">
        <div class="topic-illustration">
          <svg viewBox="0 0 80 80" fill="none">
            <circle cx="40" cy="40" r="30" stroke="#B45309" stroke-width="1" opacity="0.3"/>
            <circle cx="40" cy="40" r="18" stroke="#B45309" stroke-width="1.5" opacity="0.5"/>
            <circle cx="40" cy="40" r="6" fill="#B45309" opacity="0.6"/>
            <path d="M25 25 L55 55 M55 25 L25 55" stroke="#D97706" stroke-width="0.5" opacity="0.2"/>
          </svg>
        </div>
        <h3>Erkennung & Testung</h3>
        <p>Wie erkennt man Hochbegabung? Welche Tests gibt es? Ab welchem Alter ist eine Testung sinnvoll?</p>
      </div>

      <div class="topic-card">
        <div class="topic-illustration">
          <svg viewBox="0 0 80 80" fill="none">
            <rect x="15" y="20" width="50" height="40" rx="4" stroke="#4D7C6A" stroke-width="1" opacity="0.3"/>
            <path d="M20 50 L35 35 L45 42 L60 28" stroke="#4D7C6A" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
            <circle cx="60" cy="28" r="3" fill="#4D7C6A" opacity="0.6"/>
          </svg>
        </div>
        <h3>Schule & Förderung</h3>
        <p>Schulwahl, Überspringen, Enrichment, Akzeleration — Wege für hochbegabte Kinder im Bildungssystem.</p>
      </div>

      <div class="topic-card">
        <div class="topic-illustration">
          <svg viewBox="0 0 80 80" fill="none">
            <path d="M40 20 C25 20 15 30 15 40 C15 55 40 65 40 65 C40 65 65 55 65 40 C65 30 55 20 40 20Z" stroke="#D97706" stroke-width="1.5" opacity="0.4"/>
            <circle cx="40" cy="40" r="8" fill="#D97706" opacity="0.15"/>
            <circle cx="40" cy="40" r="3" fill="#D97706" opacity="0.5"/>
          </svg>
        </div>
        <h3>Sozial-Emotionales</h3>
        <p>Asynchrone Entwicklung, Perfektionismus, Unterforderung und der Umgang damit.</p>
      </div>

      <div class="topic-card">
        <div class="topic-illustration">
          <svg viewBox="0 0 80 80" fill="none">
            <rect x="20" y="18" width="40" height="50" rx="3" stroke="#92400E" stroke-width="1" opacity="0.3"/>
            <line x1="28" y1="30" x2="52" y2="30" stroke="#92400E" stroke-width="1" opacity="0.3"/>
            <line x1="28" y1="38" x2="48" y2="38" stroke="#92400E" stroke-width="1" opacity="0.2"/>
            <line x1="28" y1="46" x2="45" y2="46" stroke="#92400E" stroke-width="1" opacity="0.2"/>
            <circle cx="35" cy="56" r="4" fill="#92400E" opacity="0.15"/>
          </svg>
        </div>
        <h3>Ressourcen</h3>
        <p>Bücher, Anlaufstellen, Beratung und Netzwerke in Baden-Württemberg.</p>
      </div>
    </div>
  </section>

  {articles.length > 0 && (
    <section class="articles scroll-reveal">
      <h2 class="section-heading">
        <span class="heading-line"></span>
        Artikel
      </h2>
      <ul class="article-list">
        {articles.map((a, i) => (
          <li class="scroll-reveal">
            <a href={`/hochbegabung/${a.slug}/`} class="article-card">
              <div class="article-number">{String(i + 1).padStart(2, '0')}</div>
              <div class="article-content">
                {a.date && <time>{new Date(a.date).toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' })}</time>}
                <h3>{a.title}</h3>
                {a.description && <p>{a.description}</p>}
              </div>
              <span class="article-arrow">��</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- CTA -->
  <section class="hb-cta scroll-reveal">
    <div class="cta-box">
      <h2>Du suchst Austausch?</h2>
      <p>Die Elterngruppe Nürtingen / Kirchheim-Teck trifft sich regelmäßig zum Spielen und Reden.</p>
      <a href="mailto:elterngruppe-nuertingen@lvh-bw.de" class="btn-primary">Kontakt aufnehmen →</a>
    </div>
  </section>
</Base>

<style>
  .page-header { margin-bottom: 2rem; }
  .page-badge {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-secondary);
    background: var(--color-secondary-light);
    padding: 0.3rem 0.9rem;
    border-radius: 99px;
    margin-bottom: 1.25rem;
  }
  .page-intro {
    color: var(--color-muted);
    font-size: 1.1rem;
    max-width: 580px;
    line-height: 1.7;
  }

  /* Stats */
  .stats-section {
    background: rgba(255,255,255,0.5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2.5rem 2rem;
    margin: 2.5rem 0 3rem;
    max-width: 100%;
  }
  .stats-title {
    text-align: center;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-muted);
    margin: 0 0 2rem;
    font-family: var(--font-body);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-size: 0.82rem;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1.5rem;
    justify-items: center;
  }

  /* Topics */
  .section-heading {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 1.4rem;
    margin-bottom: 1.5rem;
  }
  .heading-line {
    display: block;
    width: 32px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  .topics-visual {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-bottom: 3.5rem;
  }

  .topic-card {
    background: rgba(255,255,255,0.5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.5rem;
    transition: all var(--transition);
  }
  .topic-card:hover {
    border-color: var(--color-secondary);
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .topic-illustration {
    width: 64px;
    height: 64px;
    margin-bottom: 1rem;
    transition: transform 0.4s ease;
  }
  .topic-card:hover .topic-illustration {
    transform: scale(1.1) rotate(3deg);
  }
  .topic-illustration svg {
    width: 100%;
    height: 100%;
  }

  .topic-card h3 {
    font-size: 1.1rem;
    margin: 0 0 0.4rem;
    font-weight: 600;
  }
  .topic-card p {
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.6;
    margin: 0;
  }

  /* Articles */
  .article-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 3.5rem;
  }

  .article-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem;
    background: rgba(255,255,255,0.5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: all var(--transition);
    color: var(--color-text);
    text-decoration: none;
  }
  .article-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
    transform: translateX(6px);
    color: var(--color-text);
  }

  .article-number {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 300;
    color: var(--color-border-hover);
    line-height: 1;
    flex-shrink: 0;
    width: 40px;
    text-align: center;
    font-variation-settings: 'opsz' 72;
  }
  .article-card:hover .article-number { color: var(--color-accent); }

  .article-content { flex: 1; }
  .article-content time {
    font-size: 0.8rem;
    color: var(--color-muted);
  }
  .article-content h3 {
    font-size: 1.1rem;
    margin: 0.2rem 0 0.3rem;
    font-weight: 600;
  }
  .article-content p {
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
  }

  .article-arrow {
    font-size: 1.2rem;
    color: var(--color-border-hover);
    transition: all var(--transition);
    flex-shrink: 0;
  }
  .article-card:hover .article-arrow {
    color: var(--color-accent);
    transform: translateX(4px);
  }

  /* CTA */
  .hb-cta { margin-top: 1rem; }
  .cta-box {
    background: linear-gradient(135deg, var(--color-accent-light), rgba(213, 237, 226, 0.4));
    border: 1px solid rgba(180, 83, 9, 0.15);
    border-radius: var(--radius);
    padding: 2.5rem;
    text-align: center;
  }
  .cta-box h2 { margin-top: 0; font-size: 1.5rem; }
  .cta-box p { color: var(--color-text-soft); max-width: 420px; margin: 0 auto 1.5rem; }
  .btn-primary {
    display: inline-flex;
    padding: 0.75rem 1.6rem;
    background: var(--color-accent);
    color: white;
    font-weight: 500;
    border-radius: 12px;
    transition: all var(--transition);
    text-decoration: none;
    box-shadow: 0 2px 16px var(--color-accent-glow);
  }
  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: white;
    transform: translateY(-2px);
  }

  @media (max-width: 1024px) {
    .topics-visual { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .topics-visual { grid-template-columns: 1fr; }
    .article-number { display: none; }
  }
</style>
